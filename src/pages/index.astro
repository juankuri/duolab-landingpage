---
/**
 * DúoLab conversion landing page (single static route, spec FR-013).
 *
 * Composes hero → faq → solution → how → location → social proof → final CTA
 * with content from the per-client content file. Every CTA resolves to a
 * context-specific prefilled WhatsApp message (spec FR-008).
 */
import Layout from "../layouts/Layout.astro";
import content from "../content/clients/duolab.js";

import Header from "../components/landing/Header.astro";
import Hero from "../components/landing/Hero.astro";
import SocialProof from "../components/landing/SocialProof.astro";
import About from "../components/landing/About.astro";
import Services from "../components/landing/Services.astro";
import Solution from "../components/landing/Solution.astro";
import How from "../components/landing/How.astro";
import Location from "../components/landing/Location.astro";
import Faq from "../components/landing/Faq.astro";
import ReviewUs from "../components/landing/ReviewUs.astro";
import FinalCta from "../components/landing/FinalCta.astro";
import Footer from "../components/landing/Footer.astro";
import WhatsAppFloat from "../components/landing/WhatsAppFloat.astro";

const {
  seo,
  business,
  whatsapp,
  hero,
  about,
  services,
  faq,
  solution,
  how,
  location,
  socialProof,
  reviewUs,
  finalCta,
} = content;

// Header nav: smooth-scroll anchors into the footer's info blocks (single-page).
const navLinks = [
  { label: "Horarios", href: "#horarios" },
  { label: "Ubicación", href: "#ubicacion" },
  { label: "Contacto", href: "#contacto" },
];

// Display-only business phone (spec/standing rule: shown as text, never a
// wa.me/tel CTA — the WhatsApp number is the only actionable contact).
const phoneDisplay = "938 383 0700";

// Display-only WhatsApp number (shown as text in Location; the actionable
// WhatsApp CTAs use whatsapp.phoneNumber via wa.me).
const whatsappDisplay = "938 115 6464";

// Slogan — copy.md FOOTER, verbatim.
const footerSlogan = "";

/** Resolve a context-keyed prefilled WhatsApp message into a CTA prop object. */
const ctaFor = (context: string, label: string) => ({
  phoneNumber: whatsapp.phoneNumber,
  message:
    whatsapp.messages.find((m) => m.context === context)?.text ??
    whatsapp.messages[0].text,
  label,
});

const childCare = {
  ...solution.childCareDifferentiator,
  cta: ctaFor(
    solution.childCareDifferentiator.ctaMessageContext,
    solution.childCareDifferentiator.ctaLabel,
  ),
};
---

<Layout seo={seo} business={business}>
  <Header
    brand="dúolab"
    navLinks={navLinks}
    cta={ctaFor(hero.primaryCtaMessageContext, "Escríbenos")}
  />

  <main>
    <Hero
      eyebrow={hero.eyebrow}
      headline={hero.headline}
      subheadline={hero.subheadline}
      cta={ctaFor(hero.primaryCtaMessageContext, hero.ctaLabel)}
      secondaryCta={hero.secondaryCta}
      slogan={footerSlogan}
    />

    <SocialProof
      trustSignals={socialProof.trustSignals}
      testimonials={socialProof.testimonials}
    />

    <About
      eyebrow={about.eyebrow}
      headline={about.headline}
      paragraphs={about.paragraphs}
      cta={about.cta}
    />

    <Services
      eyebrow={services.eyebrow}
      headline={services.headline}
      intro={services.intro}
      items={services.items}
      highlight={services.highlight}
      cta={ctaFor(services.ctaMessageContext, services.ctaLabel)}
    />

    <Solution
      eyebrow={solution.eyebrow}
      headline={solution.headline}
      offerPoints={solution.offerPoints}
      childCareDifferentiator={childCare}
    />

    <How
      eyebrow={how.eyebrow}
      headline={how.headline}
      steps={how.steps}
      note={how.note}
    />

    <Location
      eyebrow={location.eyebrow}
      headline={location.headline}
      business={business}
      phoneDisplay={phoneDisplay}
      whatsappDisplay={whatsappDisplay}
      directionsUrl={hero.secondaryCta.href}
    />

    <Faq
      eyebrow={faq.eyebrow}
      headline={faq.headline}
      items={faq.items}
      cta={ctaFor(faq.ctaMessageContext, faq.ctaLabel)}
    />

    <ReviewUs
      eyebrow={reviewUs.eyebrow}
      headline={reviewUs.headline}
      body={reviewUs.body}
      microcopy={reviewUs.microcopy}
      cta={reviewUs.cta}
    />

    <FinalCta
      headline={finalCta.headline}
      subheadline={finalCta.subheadline}
      cta={ctaFor(finalCta.ctaMessageContext, finalCta.ctaLabel)}
      microcopy={finalCta.microcopy}
    />
  </main>

  <Footer
    business={business}
    phoneDisplay={phoneDisplay}
    slogan={footerSlogan}
    mapUrl={hero.secondaryCta.href}
    cta={ctaFor(finalCta.ctaMessageContext, finalCta.ctaLabel)}
  />

  <WhatsAppFloat cta={ctaFor(finalCta.ctaMessageContext, finalCta.ctaLabel)} />
</Layout>
