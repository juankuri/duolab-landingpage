---
/**
 * WhatsAppButton — shared CTA used by every section.
 *
 * Renders a single <a href="https://wa.me/{phoneNumber}?text={encoded message}">.
 * No JavaScript: wa.me links work with WhatsApp installed and fall back to
 * WhatsApp Web otherwise (spec FR-008, Edge Cases; research.md CTA decision).
 *
 * Contract: src/specs/.../contracts/component-props.md
 *   phoneNumber  string  required  E.164-style digits, no "+" or spaces
 *   message      string  required  plain text; encoded here
 *   label        string  required  visible button text
 *   variant      "primary" | "outline"  default "primary"
 */
const {
  phoneNumber,
  message,
  label,
  variant = "primary",
} = Astro.props;

const href = `https://wa.me/${phoneNumber}?text=${encodeURIComponent(message)}`;
---

<a
  class:list={["wa-button", `wa-button--${variant}`]}
  href={href}
  target="_blank"
  rel="noopener noreferrer"
>
  <svg
    class="wa-button__icon"
    viewBox="0 0 24 24"
    width="20"
    height="20"
    fill="currentColor"
    aria-hidden="true"
    focusable="false"
  >
    <path
      d="M12 2a10 10 0 0 0-8.62 15.1L2 22l5.05-1.33A10 10 0 1 0 12 2Zm5.45 14.27c-.23.65-1.35 1.25-1.85 1.32-.47.07-1.06.1-1.71-.11a13.6 13.6 0 0 1-3.2-1.55 11.45 11.45 0 0 1-3.4-3.6c-.5-.78-.83-1.55-.92-2.16-.07-.5.06-1.1.42-1.5.27-.3.6-.4.8-.4h.55c.18 0 .35.02.5.36.18.4.62 1.5.67 1.6.06.1.1.23.02.38-.08.16-.13.26-.26.4-.13.15-.27.34-.39.46-.14.14-.28.3-.12.58.16.28.7 1.15 1.5 1.86.93.83 1.7 1.13 2.05 1.27.27.1.42.08.57-.08.18-.2.7-.81.9-1.08.18-.27.36-.22.6-.13.24.09 1.53.72 1.79.85.27.14.45.2.51.32.06.12.06.66-.17 1.3Z"
    ></path>
  </svg>
  <span>{label}</span>
</a>

<style>
  .wa-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-xs);
    padding: var(--space-sm) var(--space-md);
    border-radius: var(--radius-pill);
    font-family: var(--font-body);
    font-size: var(--font-size-label);
    font-weight: var(--font-weight-medium);
    line-height: 1.2;
    text-decoration: none;
    cursor: pointer;
    transition:
      background-color var(--duration-fast) var(--ease-out),
      color var(--duration-fast) var(--ease-out),
      box-shadow var(--duration-fast) var(--ease-out),
      transform var(--duration-fast) var(--ease-out);
  }

  .wa-button__icon {
    flex-shrink: 0;
  }

  /* Primary — solid purple, white text (DESIGN.md Buttons / Primary) */
  .wa-button--primary {
    background-color: var(--color-primary);
    color: var(--text-on-primary);
  }

  .wa-button--primary:hover,
  .wa-button--primary:focus-visible {
    background-color: var(--color-primary-dark);
    box-shadow: var(--shadow-cta-hover);
    transform: translateY(-1px);
  }

  /* Outline — white field, purple text + border (DESIGN.md Buttons / Secondary) */
  .wa-button--outline {
    background-color: var(--color-surface);
    color: var(--color-primary);
    border: 2px solid var(--color-primary);
    /* keep total height aligned with primary (which has no border) */
    padding: calc(var(--space-sm) - 2px) calc(var(--space-md) - 2px);
  }

  .wa-button--outline:hover,
  .wa-button--outline:focus-visible {
    background-color: var(--color-surface-soft);
  }

  .wa-button:focus-visible {
    outline: 2px solid var(--color-secondary);
    outline-offset: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .wa-button {
      transition: background-color var(--duration-fast) ease,
        color var(--duration-fast) ease;
    }

    .wa-button--primary:hover,
    .wa-button--primary:focus-visible {
      transform: none;
    }
  }
</style>
