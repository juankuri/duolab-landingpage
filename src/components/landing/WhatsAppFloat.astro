---
/**
 * WhatsAppFloat — mobile-only floating WhatsApp action.
 *
 * Contract:
 *   cta   { phoneNumber, message, label }
 *
 * Constitution Design Anti-Slop Patterns for New Sections: a generic
 * fixed-bottom-right button visible from page load is banned. This one is
 * mobile-only (desktop already surfaces the CTA in the sticky header) and
 * stays hidden until the visitor scrolls past the hero, then plays a single
 * pulse to draw the eye — never a looping animation.
 */
const { cta } = Astro.props;

const href = `https://wa.me/${cta.phoneNumber}?text=${encodeURIComponent(cta.message)}`;
---

<a
  class="wa-float"
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  aria-label={cta.label}
  data-wa-float
>
  <svg
    class="wa-float__icon"
    viewBox="0 0 24 24"
    width="26"
    height="26"
    fill="currentColor"
    aria-hidden="true"
    focusable="false"
  >
    <path
      d="M12 2a10 10 0 0 0-8.62 15.1L2 22l5.05-1.33A10 10 0 1 0 12 2Zm5.45 14.27c-.23.65-1.35 1.25-1.85 1.32-.47.07-1.06.1-1.71-.11a13.6 13.6 0 0 1-3.2-1.55 11.45 11.45 0 0 1-3.4-3.6c-.5-.78-.83-1.55-.92-2.16-.07-.5.06-1.1.42-1.5.27-.3.6-.4.8-.4h.55c.18 0 .35.02.5.36.18.4.62 1.5.67 1.6.06.1.1.23.02.38-.08.16-.13.26-.26.4-.13.15-.27.34-.39.46-.14.14-.28.3-.12.58.16.28.7 1.15 1.5 1.86.93.83 1.7 1.13 2.05 1.27.27.1.42.08.57-.08.18-.2.7-.81.9-1.08.18-.27.36-.22.6-.13.24.09 1.53.72 1.79.85.27.14.45.2.51.32.06.12.06.66-.17 1.3Z"
    ></path>
  </svg>
</a>

<style>
  .wa-float {
    display: none;
  }

  @media (max-width: 767px) {
    .wa-float {
      display: flex;
      align-items: center;
      justify-content: center;
      position: fixed;
      right: var(--space-md);
      bottom: var(--space-md);
      z-index: var(--z-sticky);
      width: 52px;
      height: 52px;
      border-radius: var(--radius-pill);
      background-color: var(--color-primary);
      color: var(--text-on-primary);
      opacity: 0;
      transform: translateY(8px) scale(0.9);
      pointer-events: none;
      transition:
        opacity var(--duration-fast) var(--ease-out),
        transform var(--duration-fast) var(--ease-out);
    }

    .wa-float.is-visible {
      opacity: 1;
      transform: translateY(0) scale(1);
      pointer-events: auto;
    }

    .wa-float:focus-visible {
      outline: 2px solid var(--color-secondary);
      outline-offset: 2px;
    }

    .wa-float.is-pulsing {
      animation: wa-float-pulse 1.4s var(--ease-out) 1;
    }
  }

  @keyframes wa-float-pulse {
    0% {
      box-shadow: 0 0 0 0 oklch(35% 0.08 295 / 0.35);
    }
    100% {
      box-shadow: 0 0 0 14px oklch(35% 0.08 295 / 0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .wa-float {
      transition: opacity var(--duration-fast) ease;
      transform: none;
    }

    .wa-float.is-pulsing {
      animation: none;
    }
  }
</style>

<script>
  // Vanilla JS only (Constitution Principle IV). Reveal past the hero, pulse
  // once on first reveal — never a looping animation (Design Anti-Slop rule).
  const el = document.querySelector<HTMLElement>("[data-wa-float]");

  if (el) {
    let hasPulsed = false;
    const revealAt = () => window.innerHeight * 0.8;

    const onScroll = () => {
      const shouldShow = window.scrollY > revealAt();
      el.classList.toggle("is-visible", shouldShow);

      if (shouldShow && !hasPulsed) {
        hasPulsed = true;
        el.classList.add("is-pulsing");
        el.addEventListener(
          "animationend",
          () => el.classList.remove("is-pulsing"),
          { once: true },
        );
      }
    };

    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });
  }
</script>
